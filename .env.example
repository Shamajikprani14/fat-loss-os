# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL and anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used for progress photos.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=progress-photos

# ---------------------------------------------------------------------------
# OpenAI (AI Coach)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
